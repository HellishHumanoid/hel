local function fireSpawnRemote()
    pcall(function()
        local remote = game:GetService("ReplicatedStorage")
            :WaitForChild("Connections", 10)
            :WaitForChild("Spawn", 10)
        remote:FireServer(2)
    end)
end

local function hookCharacter(char)
    local humanoid = char:FindFirstChildOfClass("Humanoid") or char:WaitForChild("Humanoid", 10)
    if not humanoid then return end
    humanoid.Died:Connect(function()
        -- If Auto-Package S-H is running, jump straight to a fresh server instead of waiting to respawn here
        if AutoPackageSHEnabled then
            task.spawn(serverHop)
            return
        end

        -- Otherwise keep firing the spawn remote every 1s until a fresh living character exists
        task.spawn(function()
            local diedChar = char
            while true do
                local newChar = LocalPlayer.Character
                if newChar and newChar ~= diedChar then
                    local newHum = newChar:FindFirstChildOfClass("Humanoid")
                    if newHum and newHum.Health > 0 then
                        return
                    end
                end
                fireSpawnRemote()
                task.wait(1)
            end
        end)
    end)
end

LocalPlayer.CharacterAdded:Connect(hookCharacter)
if LocalPlayer.Character then
    task.spawn(hookCharacter, LocalPlayer.Character)
end

