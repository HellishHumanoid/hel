-- Kill any previous instance so we never end up with two GUIs / two delivery loops running at once
pcall(function()
    if typeof(getgenv) == "function" and getgenv().RafsoHubFlagsApi then
        for _, api in pairs(getgenv().RafsoHubFlagsApi) do
            if type(api) == "table" and type(api.Set) == "function" then
                pcall(function() api:Set(false) end)
            end
        end
    end
    local parents = {}
    if typeof(gethui) == "function" then
        local ok, h = pcall(gethui)
        if ok and h then table.insert(parents, h) end
    end
    pcall(function() table.insert(parents, game:GetService("CoreGui")) end)
    pcall(function()
        local plr = game:GetService("Players").LocalPlayer
        if plr then table.insert(parents, plr:FindFirstChildOfClass("PlayerGui")) end
    end)
    for _, parent in ipairs(parents) do
        if parent then
            for _, child in ipairs(parent:GetChildren()) do
                if child.Name == "RafsoHub" then
                    pcall(function() child:Destroy() end)
                end
            end
        end
    end
end)

