local function saveState()
    if not writefile then return end
    local state = {
        AutoPackageSH = AutoPackageSHEnabled,
        SpecialPackageSH = SpecialPackageSHEnabled,
    }
    pcall(function()
        writefile(StateFile, HttpService:JSONEncode(state))
    end)
end

local function loadSavedState()
    if not (readfile and isfile) then return nil end
    local ok, exists = pcall(isfile, StateFile)
    if not ok or not exists then return nil end
    local ok2, data = pcall(function()
        return HttpService:JSONDecode(readfile(StateFile))
    end)
    if ok2 then return data end
    return nil
end

-- Persist visited JobIds across server hops so we never bounce back to the same one.
-- Bump this if you find yourself returning to old servers; ~36 bytes per JobId so 1000 entries ≈ 36KB.
local VisitedFile = "RafsoHub_visited.json"
local MAX_VISITED = 1000

local function loadVisitedServers()
    if not (readfile and isfile) then return {} end
    local ok, exists = pcall(isfile, VisitedFile)
    if not ok or not exists then return {} end
    local ok2, data = pcall(function()
        return HttpService:JSONDecode(readfile(VisitedFile))
    end)
    if ok2 and type(data) == "table" then return data end
    return {}
end

local function saveVisitedServers(list)
    if not writefile then return end
    pcall(function()
        writefile(VisitedFile, HttpService:JSONEncode(list))
    end)
end

local function rememberVisited(jobId)
    if not jobId then return end
    local list = loadVisitedServers()
    for i, v in ipairs(list) do
        if v == jobId then table.remove(list, i); break end
    end
    table.insert(list, jobId)
    while #list > MAX_VISITED do table.remove(list, 1) end
    saveVisitedServers(list)
end

local function queueReexec()
    if not (SCRIPT_URL and SCRIPT_URL ~= "") then return end
    local queueFn = (typeof(queue_on_teleport) == "function" and queue_on_teleport)
        or (syn and syn.queue_on_teleport)
        or (fluxus and fluxus.queue_on_teleport)
    if not queueFn then return end

    pcall(function()
        queueFn(string.format([[
if not game:IsLoaded() then game.Loaded:Wait() end
task.wait(1)
getgenv().RafsoPostHop = true
local ok, src = pcall(function() return game:HttpGet('%s?cb=' .. tostring(tick())) end)
if ok and src and #src > 200 then
    local fn = loadstring(src)
    if fn then fn() end
end
]], SCRIPT_URL))
    end)
end

-- Queue the script to re-execute on ANY teleport, not just our explicit serverHop.
-- This mirrors how Infinite Yield persists itself across server changes.
queueReexec()

local HopInProgress = false

-- Simple hop used by Auto-Package S-H: just pick a random untried public server, retry on failure
local function serverHop()
    if HopInProgress then return end
    HopInProgress = true

    local placeId = game.PlaceId
    local triedServers = { [game.JobId] = true }

    local hopFailed = false
    TeleportService.TeleportInitFailed:Connect(function(player)
        if player == LocalPlayer then hopFailed = true end
    end)

    while true do
        local servers = {}
        local ok, result = pcall(function()
            local url = string.format(
                "https://games.roblox.com/v1/games/%s/servers/Public?sortOrder=Asc&limit=100",
                placeId
            )
            return HttpService:JSONDecode(game:HttpGet(url))
        end)
        if ok and result and result.data then
            for _, s in ipairs(result.data) do
                if s.playing and s.maxPlayers
                    and s.playing < s.maxPlayers
                    and not triedServers[s.id]
                then
                    table.insert(servers, s.id)
                end
            end
        end

        queueReexec()

        hopFailed = false
        if #servers > 0 then
            local chosen = servers[math.random(1, #servers)]
            triedServers[chosen] = true
            pcall(function()
                TeleportService:TeleportToPlaceInstance(placeId, chosen, LocalPlayer)
            end)
        else
            pcall(function() TeleportService:Teleport(placeId, LocalPlayer) end)
            triedServers = { [game.JobId] = true }
        end

        local startTime = tick()
        while tick() - startTime < 8 do
            if hopFailed then break end
            task.wait(0.3)
        end

        if not hopFailed then return end
        task.wait(1)
    end
end

-- Smart hop used by the manual "Serverhop" button: prefers low-pop servers and avoids
-- ones we've already visited (persisted across sessions in RafsoHub_visited.json)
local function manualServerHop()
    if HopInProgress then return end
    HopInProgress = true

    local placeId = game.PlaceId

    rememberVisited(game.JobId)

    local triedServers = { [game.JobId] = true }
    for _, jobId in ipairs(loadVisitedServers()) do
        triedServers[jobId] = true
    end

    local hopFailed = false
    TeleportService.TeleportInitFailed:Connect(function(player)
        if player == LocalPlayer then hopFailed = true end
    end)

    while true do
        local servers = {}
        local ok, result = pcall(function()
            local url = string.format(
                "https://games.roblox.com/v1/games/%s/servers/Public?sortOrder=Asc&limit=100",
                placeId
            )
            return HttpService:JSONDecode(game:HttpGet(url))
        end)
        if ok and result and result.data then
            for _, s in ipairs(result.data) do
                if s.playing and s.maxPlayers
                    and s.playing < s.maxPlayers
                    and not triedServers[s.id]
                then
                    table.insert(servers, s)
                end
            end
        end

        -- Sort by population ascending, then pick from the lowest-population quarter
        table.sort(servers, function(a, b) return a.playing < b.playing end)

        queueReexec()

        hopFailed = false
        if #servers > 0 then
            local poolSize = math.max(1, math.ceil(#servers / 4))
            local chosen = servers[math.random(1, poolSize)]
            triedServers[chosen.id] = true
            rememberVisited(chosen.id)
            pcall(function()
                TeleportService:TeleportToPlaceInstance(placeId, chosen.id, LocalPlayer)
            end)
        else
            saveVisitedServers({})
            triedServers = { [game.JobId] = true }
            pcall(function() TeleportService:Teleport(placeId, LocalPlayer) end)
        end

        local startTime = tick()
        while tick() - startTime < 8 do
            if hopFailed then break end
            task.wait(0.3)
        end

        if not hopFailed then return end
        task.wait(1)
    end
end

-- ==================== Special Package S-H ====================

-- Special package names that trigger the keep-and-deliver behavior. Anything else
-- arriving from Retum is a "normal" package we don't care about.
local SpecialPackageNames = {
    ["Timed Package"]         = true,
    ["Special Package"]       = true,
    ["Special Timed Package"] = true,
    ["Timed Special Package"] = true,
}

local function findSpecialPackage()
    local function check(container)
        if not container then return nil end
        for _, item in ipairs(container:GetChildren()) do
            if item:IsA("Tool") and SpecialPackageNames[item.Name] then
                return item
            end
        end
        return nil
    end
    return check(LocalPlayer:FindFirstChild("Backpack")) or check(LocalPlayer.Character)
end

local function hasSpecialPackage()
    return findSpecialPackage() ~= nil
end

local function runSpecialPackageSH(isPostHop)
    if not SpecialPackageSHEnabled then return end
    local check = function() return SpecialPackageSHEnabled end

    if isPostHop then
        -- Just wait for the character to load naturally; no spawn remote, no game.Loaded
        local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
        char:WaitForChild("HumanoidRootPart", 30)
    end

    -- Fire the Retum remote and wait briefly for packages to appear
    fireRetumPackage()
    local appearTimeout = tick() + 4
    while SpecialPackageSHEnabled and not hasPackage() and tick() < appearTimeout do
        task.wait(0.2)
    end
    if not SpecialPackageSHEnabled then return end

    -- If no special package landed in inventory, hop immediately
    if not hasSpecialPackage() then
        return serverHop()
    end

    -- Equip every package (special + normals all get held simultaneously)
    equipPackage()

    -- Deliver until the special package is gone, capped at 180s for safety
    local deliveryDeadline = tick() + 180
    local maxPasses = 12
    local passes = 0
    while SpecialPackageSHEnabled and hasSpecialPackage() and passes < maxPasses and tick() < deliveryDeadline do
        passes = passes + 1
        local anyNPC = false
        for _, entry in ipairs(PackageNPCs) do
            if not SpecialPackageSHEnabled or not hasSpecialPackage() then break end
            if tick() >= deliveryDeadline then break end

            -- Sweep any newly-arrived packages from Backpack into the Character
            equipPackage()

            local root = resolveNPC(entry)
            if root then
                anyNPC = true
                local char = LocalPlayer.Character
                local hrp = char and char:FindFirstChild("HumanoidRootPart")
                if hrp then
                    local frontPos = root.Position + root.CFrame.LookVector * 3
                    hrp.CFrame = CFrame.new(frontPos, root.Position)
                    hrp.AssemblyLinearVelocity = Vector3.zero
                end
                if not interruptibleWait(1.5, check) then break end
            end
        end
        if not anyNPC then break end
    end

    -- Special package is delivered (or we timed out); don't bother with leftovers, just hop
    if not SpecialPackageSHEnabled then return end
    serverHop()
end

local function deliverPackageOnce()
    local check = function() return AutoPackageSHEnabled end

    -- Fire the Retum remote once; if no package appears within 5s, bail so the caller hops servers
    fireRetumPackage()
    local appearTimeout = tick() + 5
    while AutoPackageSHEnabled and not hasPackage() and tick() < appearTimeout do
        task.wait(0.2)
    end
    if not AutoPackageSHEnabled then return end
    if not hasPackage() then return end

    -- Once we have a package, no more than 180 seconds delivering before forcing a server hop
    local deliveryDeadline = tick() + 180

    -- Wait for at least one NPC to actually exist in workspace before starting the delivery loop
    local npcDeadline = tick() + 20
    while AutoPackageSHEnabled and tick() < npcDeadline do
        local resolved = false
        for _, entry in ipairs(PackageNPCs) do
            if resolveNPC(entry) then resolved = true; break end
        end
        if resolved then break end
        task.wait(0.3)
    end
    if not AutoPackageSHEnabled then return end

    -- Equip every package; retry briefly to make sure all current packages are in the character
    local equipDeadline = tick() + 8
    while AutoPackageSHEnabled and tick() < equipDeadline do
        equipPackage()
        if findEquippedPackage() and not findPackageInBackpack() then break end
        task.wait(0.25)
    end

    -- Deliver: iterate NPCs, capped to a few passes so we can never infinite-loop
    local maxPasses = 12
    local passes = 0
    while AutoPackageSHEnabled and hasPackage() and passes < maxPasses and tick() < deliveryDeadline do
        passes = passes + 1
        local anyNPC = false
        for _, entry in ipairs(PackageNPCs) do
            if not AutoPackageSHEnabled or not hasPackage() then break end
            if tick() >= deliveryDeadline then break end

            -- Sweep any new packages from Backpack into the Character before each NPC
            equipPackage()

            local root = resolveNPC(entry)
            if root then
                anyNPC = true
                local char = LocalPlayer.Character
                local hrp = char and char:FindFirstChild("HumanoidRootPart")
                if hrp then
                    local frontPos = root.Position + root.CFrame.LookVector * 3
                    hrp.CFrame = CFrame.new(frontPos, root.Position)
                    hrp.AssemblyLinearVelocity = Vector3.zero
                end
                if not interruptibleWait(1.5, check) then break end
            end
        end
        if not anyNPC then break end
    end
end

local function runAutoPackageSH(isPostHop)
    if not AutoPackageSHEnabled then return end

    if isPostHop then
        -- Just wait for the character to load naturally; no spawn remote, no game.Loaded wait
        local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
        char:WaitForChild("HumanoidRootPart", 30)
    end

    deliverPackageOnce()
    if not AutoPackageSHEnabled then return end

    serverHop()
end

