local function getCharacter()
    local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    return char, char:WaitForChild("HumanoidRootPart")
end

local function enableNoclip()
    if NoclipConnection then return end
    NoclipConnection = RunService.Stepped:Connect(function()
        local char = LocalPlayer.Character
        if char then
            for _, part in ipairs(char:GetDescendants()) do
                if part:IsA("BasePart") and part.CanCollide then
                    part.CanCollide = false
                end
            end
        end
    end)
end

local function disableNoclip()
    if NoclipConnection then
        NoclipConnection:Disconnect()
        NoclipConnection = nil
    end
end

local function updateNoclip()
    if AutoChestEnabled or AutoPackageEnabled or AutoPackageSHEnabled then
        enableNoclip()
    else
        disableNoclip()
    end
end

local function createPlatform()
    if Platform then return end
    local _, hrp = getCharacter()
    Platform = Instance.new("Part")
    Platform.Name = "RafsoPlatform"
    Platform.Size = Vector3.new(10, 1, 10)
    Platform.Anchored = true
    Platform.CanCollide = true
    Platform.Transparency = 1
    Platform.CFrame = CFrame.new(hrp.Position - Vector3.new(0, 3, 0))
    Platform.Parent = workspace

    task.spawn(function()
        while Platform and AutoChestEnabled do
            local char = LocalPlayer.Character
            local root = char and char:FindFirstChild("HumanoidRootPart")
            if root and Platform then
                Platform.CFrame = CFrame.new(root.Position - Vector3.new(0, 3, 0))
            end
            RunService.Heartbeat:Wait()
        end
    end)
end

local function removePlatform()
    if Platform then
        Platform:Destroy()
        Platform = nil
    end
end

local function tweenTo(hrp, targetCFrame)
    local char = LocalPlayer.Character
    local humanoid = char and char:FindFirstChildOfClass("Humanoid")

    local startCFrame = hrp.CFrame
    local distance = (startCFrame.Position - targetCFrame.Position).Magnitude
    if distance < 0.05 then
        hrp.CFrame = targetCFrame
        return
    end

    local duration = distance / TweenSpeed

    if humanoid then
        humanoid.PlatformStand = true
    end

    local elapsed = 0
    local cancelled = false
    while elapsed < duration do
        if not AutoChestEnabled then
            cancelled = true
            break
        end
        local dt = RunService.Heartbeat:Wait()
        elapsed = elapsed + dt
        local alpha = math.min(elapsed / duration, 1)
        hrp.CFrame = startCFrame:Lerp(targetCFrame, alpha)
        hrp.AssemblyLinearVelocity = Vector3.zero
        hrp.AssemblyAngularVelocity = Vector3.zero
    end

    if not cancelled then
        hrp.CFrame = targetCFrame
    end
    hrp.AssemblyLinearVelocity = Vector3.zero
    hrp.AssemblyAngularVelocity = Vector3.zero

    if humanoid then
        humanoid.PlatformStand = false
    end

    return not cancelled
end

local function runAutoChest()
    while AutoChestEnabled do
        local chests = workspace:FindFirstChild("Chests")
        if not chests then break end

        local children = chests:GetChildren()
        if #children == 0 then break end

        for _, chest in ipairs(children) do
            if not AutoChestEnabled then break end

            local pos1 = chest:FindFirstChild("Pos1")
            if pos1 and pos1:IsA("BasePart") then
                local _, hrp = getCharacter()

                local offset = pos1.CFrame.LookVector * 5
                if offset.Magnitude < 0.1 then
                    offset = Vector3.new(5, 0, 0)
                end
                local targetCFrame = CFrame.new(pos1.Position + offset, pos1.Position)

                createPlatform()
                local completed = tweenTo(hrp, targetCFrame)
                removePlatform()
                if not AutoChestEnabled then break end
                if not completed then break end

                task.wait(0.1)
                if not AutoChestEnabled then break end

                local clickDetector = pos1:FindFirstChildWhichIsA("ClickDetector")
                if clickDetector then
                    local spamStart = tick()
                    while tick() - spamStart < 0.1 do
                        if not AutoChestEnabled then break end
                        fireclickdetector(clickDetector)
                        RunService.Heartbeat:Wait()
                    end
                else
                    task.wait(0.1)
                end
                if not AutoChestEnabled then break end
            end
        end
    end
end

local function resolvePath(pathString)
    local node = nil
    for segment in string.gmatch(pathString, "[^%.]+") do
        if not node then
            if segment == "workspace" then
                node = workspace
            elseif segment == "game" then
                node = game
            else
                node = workspace:FindFirstChild(segment)
            end
        else
            node = node:FindFirstChild(segment)
        end
        if not node then return nil end
    end
    return node
end

local function resolveNPC(entry)
    local inst = typeof(entry) == "Instance" and entry or resolvePath(entry)
    if not inst then return nil end
    local root = inst:FindFirstChild("HumanoidRootPart")
        or inst:FindFirstChild("Pos1")
        or (inst:IsA("Model") and inst.PrimaryPart)
        or inst:FindFirstChildWhichIsA("BasePart")
    return root
end

local function hasPackage()
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    local char = LocalPlayer.Character
    if backpack and backpack:FindFirstChild("Package") then return true end
    if char and char:FindFirstChild("Package") then return true end
    return false
end

local function equipPackage()
    local char = LocalPlayer.Character
    local humanoid = char and char:FindFirstChildOfClass("Humanoid")
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    local tool = backpack and backpack:FindFirstChild("Package")
    if tool and humanoid then
        humanoid:EquipTool(tool)
    end
end

local function fireRetumPackage()
    local merchants = workspace:WaitForChild("Merchants", 5)
    if not merchants then return end
    local npc = merchants:WaitForChild("QuestFishMerchant", 5)
    if not npc then return end
    local clickable = npc:WaitForChild("Clickable", 5)
    if not clickable then return end
    local retum = clickable:WaitForChild("Retum", 5)
    if not retum then return end
    retum:FireServer("Package")
end

local function interruptibleWait(seconds)
    local start = tick()
    while tick() - start < seconds do
        if not AutoPackageEnabled then return false end
        task.wait(0.05)
    end
    return true
end

local function runM1Spam()
    if M1SpamActive then return end
    M1SpamActive = true
    while AutoPackageEnabled or AutoPackageSHEnabled do
        local char = LocalPlayer.Character
        local tool = char and char:FindFirstChildOfClass("Tool")
        if tool then
            pcall(function()
                tool:Activate()
            end)
        end
        task.wait(0.1)
    end
    M1SpamActive = false
end

local function runAutoPackage()
    while AutoPackageEnabled do
        fireRetumPackage()

        -- Wait up to 5s for the package to spawn in the backpack
        local appearTimeout = tick() + 5
        while AutoPackageEnabled and not hasPackage() and tick() < appearTimeout do
            task.wait(0.1)
        end
        if not AutoPackageEnabled then break end

        if hasPackage() then
            equipPackage()

            -- Teleport through the NPC list until the package is delivered
            while AutoPackageEnabled and hasPackage() do
                local anyNPC = false
                for _, entry in ipairs(PackageNPCs) do
                    if not AutoPackageEnabled or not hasPackage() then break end

                    local root = resolveNPC(entry)
                    if root then
                        anyNPC = true
                        local _, hrp = getCharacter()
                        if hrp then
                            local frontPos = root.Position + root.CFrame.LookVector * 3
                            hrp.CFrame = CFrame.new(frontPos, root.Position)
                            hrp.AssemblyLinearVelocity = Vector3.zero
                        end
                        if not interruptibleWait(0.5) then break end
                    end
                end
                if not anyNPC then break end
            end
        end

        if not AutoPackageEnabled then break end

        -- Cooldown before firing the remote again
        if not interruptibleWait(60) then break end
    end
end

local function interruptibleWaitSH(seconds)
    local start = tick()
    while tick() - start < seconds do
        if not AutoPackageSHEnabled then return false end
        task.wait(0.05)
    end
    return true
end

local function saveState()
    if not writefile then return end
    local state = {
        AutoPackageSH = AutoPackageSHEnabled,
    }
    pcall(function()
        writefile(StateFile, HttpService:JSONEncode(state))
    end)
end

local function loadSavedState()
    if not (readfile and isfile) then return nil end
    local ok, exists = pcall(isfile, StateFile)
    if not ok or not exists then return nil end
    local ok2, data = pcall(function()
        return HttpService:JSONDecode(readfile(StateFile))
    end)
    if ok2 then return data end
    return nil
end

local function queueReexec()
    if not queue_on_teleport then return end
    if SCRIPT_URL and SCRIPT_URL ~= "" then
        pcall(function()
            queue_on_teleport(string.format(
                "getgenv().RafsoPostHop = true; loadstring(game:HttpGet('%s'))()",
                SCRIPT_URL
            ))
        end)
    end
end

local function serverHop()
    local placeId = game.PlaceId
    local servers = {}
    local ok, result = pcall(function()
        local url = string.format(
            "https://games.roblox.com/v1/games/%s/servers/Public?sortOrder=Asc&limit=100",
            placeId
        )
        return HttpService:JSONDecode(game:HttpGet(url))
    end)
    if ok and result and result.data then
        for _, server in ipairs(result.data) do
            if server.playing and server.maxPlayers
                and server.playing < server.maxPlayers
                and server.id ~= game.JobId
            then
                table.insert(servers, server.id)
            end
        end
    end

    queueReexec()

    if #servers > 0 then
        local chosen = servers[math.random(1, #servers)]
        pcall(function()
            TeleportService:TeleportToPlaceInstance(placeId, chosen, LocalPlayer)
        end)
    else
        pcall(function()
            TeleportService:Teleport(placeId, LocalPlayer)
        end)
    end
end

local function deliverPackageOnce()
    fireRetumPackage()

    local appearTimeout = tick() + 5
    while AutoPackageSHEnabled and not hasPackage() and tick() < appearTimeout do
        task.wait(0.1)
    end
    if not AutoPackageSHEnabled then return end

    if hasPackage() then
        equipPackage()

        while AutoPackageSHEnabled and hasPackage() do
            local anyNPC = false
            for _, entry in ipairs(PackageNPCs) do
                if not AutoPackageSHEnabled or not hasPackage() then break end

                local root = resolveNPC(entry)
                if root then
                    anyNPC = true
                    local _, hrp = getCharacter()
                    if hrp then
                        local frontPos = root.Position + root.CFrame.LookVector * 3
                        hrp.CFrame = CFrame.new(frontPos, root.Position)
                        hrp.AssemblyLinearVelocity = Vector3.zero
                    end
                    if not interruptibleWaitSH(0.5) then break end
                end
            end
            if not anyNPC then break end
        end
    end
end

local function runAutoPackageSH(isPostHop)
    if not AutoPackageSHEnabled then return end

    if isPostHop then
        if not game:IsLoaded() then
            game.Loaded:Wait()
        end
        pcall(function()
            local remote = game:GetService("ReplicatedStorage")
                :WaitForChild("Connections", 10)
                :WaitForChild("Spawn", 10)
            remote:FireServer(2)
        end)
        if not interruptibleWaitSH(5) then return end
    end

    deliverPackageOnce()
    if not AutoPackageSHEnabled then return end

    serverHop()
end

