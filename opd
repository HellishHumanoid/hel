local function fireRetumPackage()
    local merchants = workspace:WaitForChild("Merchants", 5)
    if not merchants then return end
    local npc = merchants:WaitForChild("QuestFishMerchant", 5)
    if not npc then return end
    local clickable = npc:WaitForChild("Clickable", 5)
    if not clickable then return end
    local retum = clickable:WaitForChild("Retum", 5)
    if not retum then return end
    retum:FireServer("Package")
end

local function interruptibleWait(seconds, checkFn)
    local start = tick()
    while tick() - start < seconds do
        if not checkFn() then return false end
        task.wait(0.05)
    end
    return true
end

