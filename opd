-- ==================== Helpers ====================

local function getCharacter()
    local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    return char, char:WaitForChild("HumanoidRootPart")
end

local function enableNoclip()
    if NoclipConnection then return end
    NoclipConnection = RunService.Stepped:Connect(function()
        if not LocalPlayer then return end
        local char = LocalPlayer.Character
        if not char then return end
        for _, part in ipairs(char:GetDescendants()) do
            if part:IsA("BasePart") and part.CanCollide then
                part.CanCollide = false
            end
        end
    end)
end

local function disableNoclip()
    if NoclipConnection then
        NoclipConnection:Disconnect()
        NoclipConnection = nil
    end
end

local function updateNoclip()
    if AutoChestEnabled or AutoPackageEnabled or AutoPackageSHEnabled or SpecialPackageSHEnabled then
        enableNoclip()
    else
        disableNoclip()
    end
end

local PlatformConsumers = {}
local PLATFORM_OFFSET = 3.5

local function shouldPlatformExist()
    return next(PlatformConsumers) ~= nil
end

local function createPlatform(consumer)
    PlatformConsumers[consumer or "default"] = true
    if Platform then return end
    local _, hrp = getCharacter()
    Platform = Instance.new("Part")
    Platform.Name = "RafsoPlatform"
    Platform.Size = Vector3.new(10, 1, 10)
    Platform.Anchored = true
    Platform.CanCollide = true
    Platform.Transparency = 1
    Platform.CFrame = CFrame.new(hrp.Position - Vector3.new(0, PLATFORM_OFFSET, 0))
    Platform.Parent = workspace

    task.spawn(function()
        while Platform and shouldPlatformExist() do
            local char = LocalPlayer.Character
            local root = char and char:FindFirstChild("HumanoidRootPart")
            if root and Platform then
                Platform.CFrame = CFrame.new(root.Position - Vector3.new(0, PLATFORM_OFFSET, 0))
            end
            RunService.Heartbeat:Wait()
        end
    end)
end

local function removePlatform(consumer)
    PlatformConsumers[consumer or "default"] = nil
    if shouldPlatformExist() then return end
    if Platform then
        Platform:Destroy()
        Platform = nil
    end
end

local function tweenTo(hrp, targetCFrame)
    local char = LocalPlayer.Character
    local humanoid = char and char:FindFirstChildOfClass("Humanoid")

    local startCFrame = hrp.CFrame
    local distance = (startCFrame.Position - targetCFrame.Position).Magnitude
    if distance < 0.05 then
        hrp.CFrame = targetCFrame
        return true
    end

    local duration = distance / TweenSpeed

    if humanoid then humanoid.PlatformStand = true end

    local elapsed = 0
    local cancelled = false
    while elapsed < duration do
        if not AutoChestEnabled then cancelled = true; break end
        local dt = RunService.Heartbeat:Wait()
        elapsed = elapsed + dt
        local alpha = math.min(elapsed / duration, 1)
        hrp.CFrame = startCFrame:Lerp(targetCFrame, alpha)
        hrp.AssemblyLinearVelocity = Vector3.zero
        hrp.AssemblyAngularVelocity = Vector3.zero
    end

    if not cancelled then hrp.CFrame = targetCFrame end
    hrp.AssemblyLinearVelocity = Vector3.zero
    hrp.AssemblyAngularVelocity = Vector3.zero
    if humanoid then humanoid.PlatformStand = false end

    return not cancelled
end

local function resolvePath(pathString)
    local node = nil
    for segment in string.gmatch(pathString, "[^%.]+") do
        if not node then
            if segment == "workspace" then node = workspace
            elseif segment == "game" then node = game
            else node = workspace:FindFirstChild(segment) end
        else
            node = node:FindFirstChild(segment)
        end
        if not node then return nil end
    end
    return node
end

local function resolveNPC(entry)
    local inst = typeof(entry) == "Instance" and entry or resolvePath(entry)
    if not inst then return nil end
    return inst:FindFirstChild("HumanoidRootPart")
        or inst:FindFirstChild("Pos1")
        or (inst:IsA("Model") and inst.PrimaryPart)
        or inst:FindFirstChildWhichIsA("BasePart")
end

local function isPackageTool(item)
    return item and item:IsA("Tool") and string.find(item.Name, "Package") ~= nil
end

local function findPackageInBackpack()
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    if not backpack then return nil end
    for _, item in ipairs(backpack:GetChildren()) do
        if isPackageTool(item) then return item end
    end
    return nil
end

local function findEquippedPackage()
    local char = LocalPlayer.Character
    if not char then return nil end
    for _, item in ipairs(char:GetChildren()) do
        if isPackageTool(item) then return item end
    end
    return nil
end

local function hasPackage()
    return findEquippedPackage() ~= nil or findPackageInBackpack() ~= nil
end

local function equipPackage()
    -- Reparent every package-named tool from Backpack into the Character so they're all equipped at once.
    local char = LocalPlayer.Character
    if not char then return end
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    if not backpack then return end
    for _, item in ipairs(backpack:GetChildren()) do
        if isPackageTool(item) then
            pcall(function() item.Parent = char end)
        end
    end
end

local function isDrinkTool(item)
    if not (item and item:IsA("Tool")) then return false end
    local name = item.Name
    return string.find(name, "Cider") ~= nil
        or string.find(name, "Smoothie") ~= nil
        or string.find(name, "Lemonade") ~= nil
        or string.find(name, "Juice") ~= nil
end

local function findDrinkInBackpack()
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    if not backpack then return nil end
    for _, item in ipairs(backpack:GetChildren()) do
        if isDrinkTool(item) then return item end
