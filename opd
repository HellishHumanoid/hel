local function runM1Spam()
    if M1SpamActive then return end
    M1SpamActive = true
    while AutoPackageEnabled or AutoPackageSHEnabled or SpecialPackageSHEnabled do
        local char = LocalPlayer.Character
        if char then
            for _, item in ipairs(char:GetChildren()) do
                if isPackageTool(item) then
                    pcall(function() item:Activate() end)
                end
            end
        end
        task.wait(0.1)
    end
    M1SpamActive = false
end

local function runAutoChest()
    while AutoChestEnabled do
        local chests = workspace:FindFirstChild("Chests")
        if not chests then break end

        local children = chests:GetChildren()
        if #children == 0 then break end

        for _, chest in ipairs(children) do
            if not AutoChestEnabled then break end
            local pos1 = chest:FindFirstChild("Pos1")
            if pos1 and pos1:IsA("BasePart") then
                local _, hrp = getCharacter()
                local offset = pos1.CFrame.LookVector * 5
                if offset.Magnitude < 0.1 then offset = Vector3.new(5, 0, 0) end
                local targetCFrame = CFrame.new(pos1.Position + offset, pos1.Position)

                createPlatform("chest")
                local completed = tweenTo(hrp, targetCFrame)
                removePlatform("chest")
                if not AutoChestEnabled then break end
                if not completed then break end

                task.wait(0.1)
                if not AutoChestEnabled then break end

                local clickDetector = pos1:FindFirstChildWhichIsA("ClickDetector")
                if clickDetector then
                    local spamStart = tick()
                    while tick() - spamStart < 0.1 do
                        if not AutoChestEnabled then break end
                        fireclickdetector(clickDetector)
                        RunService.Heartbeat:Wait()
                    end
                else
                    task.wait(0.1)
                end
                if not AutoChestEnabled then break end
            end
        end
    end
end

local function setHRPAnchored(state)
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if hrp then
        pcall(function() hrp.Anchored = state end)
    end
    return hrp
end

local function runAutoPackage()
    local check = function() return AutoPackageEnabled end
    while AutoPackageEnabled do
        -- Make sure HRP is movable before this iteration's delivery
        setHRPAnchored(false)

        fireRetumPackage()

        local appearTimeout = tick() + 5
        while AutoPackageEnabled and not hasPackage() and tick() < appearTimeout do
            task.wait(0.1)
        end
        if not AutoPackageEnabled then break end

        if hasPackage() then
            equipPackage()
            while AutoPackageEnabled and hasPackage() do
                local anyNPC = false
                for _, entry in ipairs(PackageNPCs) do
                    if not AutoPackageEnabled or not hasPackage() then break end

                    -- Sweep any newly-arrived packages from Backpack into the Character
                    equipPackage()

                    local root = resolveNPC(entry)
                    if root then
                        anyNPC = true
                        local _, hrp = getCharacter()
                        if hrp then
                            local frontPos = root.Position + root.CFrame.LookVector * 3
                            hrp.CFrame = CFrame.new(frontPos, root.Position)
                            hrp.AssemblyLinearVelocity = Vector3.zero
                        end
                        if not interruptibleWait(1.5, check) then break end
                    end
                end
                if not anyNPC then break end
            end
        end

        if not AutoPackageEnabled then break end

        -- 1.5s after delivery, teleport to (1000, 1000, 1000) and anchor as a safe zone
        if not interruptibleWait(1.5, check) then break end
        local char = LocalPlayer.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        if hrp then
            hrp.CFrame = CFrame.new(1000, 1000, 1000)
            hrp.AssemblyLinearVelocity = Vector3.zero
            hrp.AssemblyAngularVelocity = Vector3.zero
            pcall(function() hrp.Anchored = true end)
        end

        -- Cooldown while sitting in the safe zone
        if not interruptibleWait(1, check) then break end
    end

    -- Ensure HRP is unanchored when the loop exits (toggle off, etc.)
    setHRPAnchored(false)
end

