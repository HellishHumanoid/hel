-- State
local selectedTypes = {}
local autoRunning = false

-- Name patterns for each chest type (case-insensitive, locked chests are always skipped)
local TYPE_PATTERNS = {
    ["Emerald Chest"] = "emerald",
    ["Golden Chest"]  = "golden",
    ["Silver Chest"]  = "silver",
    ["Wooden Chest"]  = "wooden",
}

-- Priority order
local PRIORITY = {"Emerald Chest", "Golden Chest", "Silver Chest", "Wooden Chest"}

-- Builds an ordered chest list respecting priority (Emerald > Golden > Silver > Wooden)
-- Skips any chest whose name contains "locked"
local function getChests()
    local list = {}
    local seen = {}

    for _, typeName in ipairs(PRIORITY) do
        if selectedTypes[typeName] then
            local pattern = TYPE_PATTERNS[typeName]
            for _, chest in ipairs(workspace.Chests:GetChildren()) do
                local name = chest.Name:lower()
                if name:find(pattern) and not name:find("locked") and not seen[chest] then
                    table.insert(list, chest)
                    seen[chest] = true
                end
            end
        end
    end

    return list
end

local function teleportToChest(chest)
    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    -- GetPivot() works even when parts haven't streamed in yet,
    -- teleporting there causes Roblox to stream in the nearby content
    local ok, pivot = pcall(function() return chest:GetPivot() end)
    if ok and pivot then
        hrp.CFrame = pivot + Vector3.new(0, 3, 0)
    else
        local main = chest:FindFirstChild("Main")
        if not main then return end
        hrp.CFrame = main.CFrame + Vector3.new(0, 3, 0)
    end
end

local function fireChest(chest)
    -- WaitForChild blocks until the part streams in (up to 10 seconds)
    local main = chest:WaitForChild("Main", 10)
    if not main then return end
    local cd = main:WaitForChild("ClickDetector", 10)
    if not cd then return end
    fireclickdetector(cd)
end

local function autoChestLoop()
    while autoRunning do
        local visited = {}
        local foundNew = true

        -- Inner loop: keep fetching the chest list after each teleport so
        -- newly streamed-in chests are picked up as we move around the map.
        while autoRunning and foundNew do
            foundNew = false
            local chests = getChests()

            for _, chest in ipairs(chests) do
                if not visited[chest] then
                    foundNew = true
                    visited[chest] = true
                    pcall(teleportToChest, chest)
                    task.wait(0.2)
                    pcall(fireChest, chest)
                    pcall(fireChest, chest)
                    pcall(fireChest, chest)
                    break -- re-fetch list so newly loaded chests are included
                end
            end
        end

        -- All discoverable chests done; pause before starting a new cycle
        if autoRunning then
            task.wait(1)
        end
    end
end

-- ── Auto-Fruit ────────────────────────────────────────────────────────────────

local fruitRunning = false

-- Fruits are direct workspace children identified by always containing
-- both "DestroyScript" and "InstaWeld", regardless of their random name.
local function getAllFruits()
    local fruits = {}
    for _, obj in ipairs(workspace:GetChildren()) do
        if obj:FindFirstChild("DestroyScript") and obj:FindFirstChild("InstaWeld") then
            table.insert(fruits, obj)
        end
    end
    return fruits
end

local function setFrozen(frozen)
    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if hrp then hrp.Anchored = frozen end
end

local function autoFruitLoop()
    local visited = {}

    while fruitRunning do
        local fruits = getAllFruits()
        local acted = false

        for _, fruit in ipairs(fruits) do
            if not fruitRunning then break end
            if not visited[fruit] then
                visited[fruit] = true
                acted = true

                local char = LocalPlayer.Character
                local hrp = char and char:FindFirstChild("HumanoidRootPart")
                if not hrp then break end

                -- Teleport to model first so Handle can stream in
                setFrozen(true)
                local ok, pivot = pcall(function() return fruit:GetPivot() end)
                if ok and pivot then
                    hrp.CFrame = pivot + Vector3.new(0, 3, 0)
                end

                -- Wait for Handle + ClickDetector to stream in
                local handle = fruit:WaitForChild("Handle", 10)
                local cd = handle and handle:WaitForChild("ClickDetector", 5)

                -- Loop: freeze → teleport → unfreeze → fire, until fruit leaves workspace
                if cd then
                    while fruitRunning and fruit.Parent ~= nil do
                        setFrozen(true)
                        local pok, pos = pcall(function() return fruit:GetPivot() end)
                        if pok and pos then
                            hrp.CFrame = pos + Vector3.new(0, 3, 0)
                        end
                        setFrozen(false)
                        pcall(fireclickdetector, cd)
                        task.wait()
                    end
                else
                    setFrozen(false)
                end

                break -- re-check immediately for more / newly spawned fruits
            end
        end

        if not acted then
            task.wait(0.1) -- no new fruit yet, keep polling
        end
    end

    setFrozen(false)
end

