-- ── Autofarm ──────────────────────────────────────────────────────────────────

local RunService        = game:GetService("RunService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local autofarmRunning = false
local selectedMobs    = {}
local currentFarmMob  = nil
local farmAtSpawn     = false

local noclipConn = nil
local lockConn   = nil

local SPAWN_POINT = CFrame.new(-1117, 36, 2427)

-- Noclip: disable collision on every character part each physics step
local function enableNoclip()
    noclipConn = RunService.Stepped:Connect(function()
        local char = LocalPlayer.Character
        if not char then return end
        for _, part in ipairs(char:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = false
            end
        end
    end)
end

local function disableNoclip()
    if noclipConn then noclipConn:Disconnect(); noclipConn = nil end
    local char = LocalPlayer.Character
    if not char then return end
    for _, part in ipairs(char:GetDescendants()) do
        if part:IsA("BasePart") then
            part.CanCollide = true
        end
    end
end

-- Position lock: runs every heartbeat frame — no anchoring so attacks still work
local function startLock()
    lockConn = RunService.Heartbeat:Connect(function()
        local char = LocalPlayer.Character
        local hrp  = char and char:FindFirstChild("HumanoidRootPart")
        local hum  = char and char:FindFirstChildWhichIsA("Humanoid")
        if not hrp then return end

        if currentFarmMob and currentFarmMob.Parent then
            local mobHRP = currentFarmMob:FindFirstChild("HumanoidRootPart")
            if mobHRP then
                if hum then hum:ChangeState(Enum.HumanoidStateType.Physics) end
                hrp.CFrame = CFrame.new(mobHRP.Position + Vector3.new(0, -7, 0))
                           * CFrame.Angles(math.pi / 2, 0, 0)
                hrp.AssemblyLinearVelocity  = Vector3.zero
                hrp.AssemblyAngularVelocity = Vector3.zero
            end
        elseif farmAtSpawn then
            if hum then hum:ChangeState(Enum.HumanoidStateType.Physics) end
            hrp.CFrame = SPAWN_POINT
            hrp.AssemblyLinearVelocity  = Vector3.zero
            hrp.AssemblyAngularVelocity = Vector3.zero
        end
    end)
end

local function stopLock()
    if lockConn then lockConn:Disconnect(); lockConn = nil end
end

-- Mob sources: maps dropdown label → function returning live mob list
local MOB_SOURCES = {
    ["Marine Soldier"] = function()
        local folder = workspace:FindFirstChild("Players")
        if not folder then return {} end
        local list = {}
        for _, npc in ipairs(folder:GetChildren()) do
            if npc.Name == "MarineSoldier" then
                table.insert(list, npc)
            end
        end
        return list
    end,
}

local function getMobs()
    local list = {}
    for mobType, getter in pairs(MOB_SOURCES) do
        if selectedMobs[mobType] then
            for _, mob in ipairs(getter()) do
                table.insert(list, mob)
            end
        end
    end
    return list
end

local function isMobAlive(mob)
    if not mob or mob.Parent == nil then return false end
    local hum = mob:FindFirstChildWhichIsA("Humanoid")
    return not hum or hum.Health > 0
end

local function getM1Remote()
    local char    = LocalPlayer.Character
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    local tool = (char and char:FindFirstChild("Combat"))
              or (backpack and backpack:FindFirstChild("Combat"))
    if not tool then return nil end
    local handler = tool:FindFirstChild("CombatHandler")
    if not handler then return nil end
    return handler:FindFirstChild("M1")
end

local function getMoveHandlerQuake()
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    local char     = LocalPlayer.Character
    return (backpack and backpack:FindFirstChild("MoveHandler_Quake"))
        or (char     and char:FindFirstChild("MoveHandler_Quake"))
end

local function fireAllAttacks()
    local m1 = getM1Remote()
    if m1 then
        m1:FireServer("Combo", nil, { HoldingRMB = false })
    end

    local skillRemote = ReplicatedStorage:FindFirstChild("ActivateSkillClient")
    local moveHandler = getMoveHandlerQuake()
    if skillRemote and moveHandler then
        skillRemote:FireServer("DF_Quake_SevereEarthquake", "Down", moveHandler)
        skillRemote:FireServer("DF_Quake_Tremor",           "Up",   moveHandler)
        skillRemote:FireServer("DF_Quake_HelmetSplitter",   "Down", moveHandler)
        skillRemote:FireServer("DF_Quake_HeavenEarth",      "Up",   moveHandler)
        skillRemote:FireServer("DF_Quake_SeaQuake",         "Down", moveHandler)
    end
end

local function autofarmLoop()
    enableNoclip()
    startLock()
    farmAtSpawn = true

    -- Continuously keep Combat equipped while Autofarm is on
    task.spawn(function()
        while autofarmRunning do
            local char = LocalPlayer.Character
            if char and not char:FindFirstChild("Combat") then
                equipCombat()
            end
            task.wait(1)
        end
    end)

    while autofarmRunning do
        local mobs   = getMobs()
        local fought = false

        for _, mob in ipairs(mobs) do
            if not autofarmRunning then break end
            if isMobAlive(mob) then
                fought       = true
                farmAtSpawn  = false
                currentFarmMob = mob

                -- Heartbeat handles position; just fire attacks until mob dies
                while autofarmRunning and isMobAlive(mob) do
                    fireAllAttacks()
                    task.wait(0.2)
                end

                currentFarmMob = nil
                break
            end
        end

        if not fought then
            -- No alive mobs; park at spawn and wait for next wave
            currentFarmMob = nil
            farmAtSpawn    = true
            task.wait(0.5)
        end
    end

    -- Cleanup
    currentFarmMob = nil
    farmAtSpawn    = false
    stopLock()
    disableNoclip()

    local char = LocalPlayer.Character
    local hum  = char and char:FindFirstChildWhichIsA("Humanoid")
    if hum then hum:ChangeState(Enum.HumanoidStateType.GettingUp) end
end

-- ── Auto-Player ───────────────────────────────────────────────────────────────

local playerFarmRunning   = false
local selectedPlayers     = {}
local currentPlayerTarget = nil

local playerNoclipConn = nil
local playerLockConn   = nil

local function getTargetPlayers()
    local list = {}
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and (next(selectedPlayers) == nil or selectedPlayers[player.Name]) then
            local char = player.Character
            if char then
                local hum = char:FindFirstChildWhichIsA("Humanoid")
                if hum and hum.Health > 0 then
                    table.insert(list, char)
                end
            end
        end
    end
    return list
end

local function isPlayerAlive(char)
    if not char or char.Parent == nil then return false end
    local hum = char:FindFirstChildWhichIsA("Humanoid")
    return hum ~= nil and hum.Health > 0
end

local function enablePlayerNoclip()
    playerNoclipConn = RunService.Stepped:Connect(function()
        local char = LocalPlayer.Character
        if not char then return end
        for _, part in ipairs(char:GetDescendants()) do
            if part:IsA("BasePart") then part.CanCollide = false end
        end
    end)
end

local function disablePlayerNoclip()
    if playerNoclipConn then playerNoclipConn:Disconnect(); playerNoclipConn = nil end
    local char = LocalPlayer.Character
    if not char then return end
    for _, part in ipairs(char:GetDescendants()) do
        if part:IsA("BasePart") then part.CanCollide = true end
    end
end

local function startPlayerLock()
    playerLockConn = RunService.Heartbeat:Connect(function()
        if not currentPlayerTarget or not currentPlayerTarget.Parent then return end
        local char      = LocalPlayer.Character
        local hrp       = char and char:FindFirstChild("HumanoidRootPart")
        local hum       = char and char:FindFirstChildWhichIsA("Humanoid")
        local targetHRP = currentPlayerTarget:FindFirstChild("HumanoidRootPart")
        if hrp and targetHRP then
            if hum then hum:ChangeState(Enum.HumanoidStateType.Physics) end
            hrp.CFrame = CFrame.new(targetHRP.Position + Vector3.new(0, -7, 0))
                       * CFrame.Angles(math.pi / 2, 0, 0)
            hrp.AssemblyLinearVelocity  = Vector3.zero
            hrp.AssemblyAngularVelocity = Vector3.zero
        end
    end)
end

local function stopPlayerLock()
    if playerLockConn then playerLockConn:Disconnect(); playerLockConn = nil end
end

local function autoPlayerLoop()
    enablePlayerNoclip()
    startPlayerLock()

    while playerFarmRunning do
        local targets = getTargetPlayers()
        local fought  = false

        for _, char in ipairs(targets) do
            if not playerFarmRunning then break end
            if isPlayerAlive(char) then
                fought              = true
                currentPlayerTarget = char

                while playerFarmRunning and isPlayerAlive(char) do
                    fireAllAttacks()
                    task.wait(0.2)
                end

                currentPlayerTarget = nil
                break
            end
        end

        if not fought then
            currentPlayerTarget = nil
            task.wait(0.5)
        end
    end

    currentPlayerTarget = nil
    stopPlayerLock()
    disablePlayerNoclip()

    local char = LocalPlayer.Character
    local hum  = char and char:FindFirstChildWhichIsA("Humanoid")
    if hum then hum:ChangeState(Enum.HumanoidStateType.GettingUp) end
end

-- Saves current toggle/dropdown state to disk so it survives server hops
local function saveConfig()
    pcall(function()
        writefile(CONFIG_PATH, HttpService:JSONEncode({
            autoRunning       = autoRunning,
            fruitRunning      = fruitRunning,
            autofarmRunning   = autofarmRunning,
            playerFarmRunning = playerFarmRunning,
            selectedTypes     = selectedTypes,
            selectedMobs      = selectedMobs,
            selectedPlayers   = selectedPlayers,
        }))
    end)
end

-- ── Spawn handler ─────────────────────────────────────────────────────────────

local function equipCombat()
    -- Wait for backpack and Combat tool to be ready
    local backpack = LocalPlayer:WaitForChild("Backpack", 10)
    if not backpack then return end

    local combat = backpack:WaitForChild("Combat", 10)
    if not combat then return end

    -- Equip the tool so the server recognises it as held
    local char = LocalPlayer.Character
    local hum  = char and char:FindFirstChildWhichIsA("Humanoid")
    if hum then
        hum:EquipTool(combat)
        task.wait(0.5) -- let the equip register before firing the remote
    end

    -- Fire EquipWeapon to set One Sword Style server-side
    local handler     = combat:WaitForChild("CombatHandler", 10)
    local equipRemote = handler and handler:WaitForChild("EquipWeapon", 10)
    if equipRemote then
        equipRemote:FireServer("OneSwordStyle")
    end
end

-- Equip on every spawn / death / reset while Autofarm is on
LocalPlayer.CharacterAdded:Connect(function()
    task.wait(2) -- give the server time to populate the Backpack
    if autofarmRunning then
        equipCombat()
    end
end)

