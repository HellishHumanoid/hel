-- ── Config persistence ────────────────────────────────────────────────────────
local CONFIG_PATH = "AutoChest_Config.json"

-- Loads saved config from disk; returns empty table if none exists yet
local function loadConfig()
    local ok, raw = pcall(readfile, CONFIG_PATH)
    if not ok or not raw or raw == "" then return {} end
    local ok2, data = pcall(HttpService.JSONDecode, HttpService, raw)
    return ok2 and data or {}
end

-- Converts a {[key]=true} set back to a plain array for dropdown CurrentOption
local function keysToArray(t)
    local arr = {}
    if t then for k in pairs(t) do table.insert(arr, k) end end
    return arr
end

